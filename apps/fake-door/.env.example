# ── 推荐：lark-cli 全自动模式（运行 scripts/setup-feishu-bitable.sh 后自动填入）──
FEISHU_LEAD_MODE=bitable
FEISHU_BASE_TOKEN=
FEISHU_TABLE_ID=
# bot 身份需先在开放平台申请 base 权限；默认用 user 身份（lark-cli auth login --domain base）
FEISHU_IDENTITY=user

# ── 备选：手动在飞书 UI 配置的自动化 webhook ──
# FEISHU_WEBHOOK_URL=https://www.feishu.cn/flow/api/trigger-webhook/xxxxxxxx

# 可选：前端提交地址，默认 /api/leads
# VITE_LEAD_API_URL=/api/leads